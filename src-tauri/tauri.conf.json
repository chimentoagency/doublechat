{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DoubleChat",
  "version": "0.1.0",
  "identifier": "com.doublechat.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DoubleChat",
        "width": 960,
        "height": 680,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; media-src blob: mediastream:; connect-src 'self' ws: wss:; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU5RkUwOURCNTBCRUE2NUUKUldSZXByNVEyd24rNmJOLzFBOHFObnNhRXFKZVRxdkVab0ladTg3WEZ4UzVGNVJXRjRzRXhkYTMK",
      "endpoints": [
        "https://github.com/chimentoagency/doublechat/releases/latest/download/latest.json"
      ]
    }
  }
}
